# Provider Selection
LLM_PROVIDER=openai  # openai, qwen, glm
EMBEDDING_PROVIDER=openai  # openai, qwen, glm

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_GENERATION_MODEL=gpt-5.2
OPENAI_CHAT_MODEL=gpt-5-mini

# Qwen (DashScope)
QWEN_API_KEY=your_qwen_api_key_here
QWEN_GENERATION_MODEL=qwen-max
QWEN_CHAT_MODEL=qwen-plus
QWEN_EMBEDDING_MODEL=text-embedding-v3

# PostgreSQL
POSTGRES_USER=book2skills
POSTGRES_PASSWORD=book2skills_password
POSTGRES_DB=book2skills
DATABASE_URL=postgresql+asyncpg://book2skills:book2skills_password@postgres:5432/book2skills

# Redis
REDIS_URL=redis://redis:6379/0

# Qdrant
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=

# Storage (local MinIO or S3)
STORAGE_TYPE=local
STORAGE_LOCAL_PATH=/app/storage
# For S3 (production):
# STORAGE_TYPE=s3
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_BUCKET=book2skills
# AWS_REGION=us-east-1

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000

# App
DEBUG=true
MAX_FILE_SIZE_MB=50
CHUNK_SIZE=800
CHUNK_OVERLAP=100
RETRIEVAL_TOP_K=5
RETRIEVAL_CANDIDATE_K=50
RETRIEVAL_MIN_SCORE=0.0
SKILL_RETRIEVAL_TOP_K=8
# Hybrid search weights (vector + BM25)
RETRIEVAL_VECTOR_WEIGHT=0.6
RETRIEVAL_BM25_WEIGHT=0.4
# Query expansion: set to true to enable LLM-based multi-query for short/ambiguous queries
RETRIEVAL_USE_QUERY_EXPANSION=false
RETRIEVAL_QUERY_EXPANSION_N=3
